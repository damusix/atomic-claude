-- Seed: sentinel rows for Agent and Project (id = 0 means "no attribution / no provenance").
-- Source: tmp/llm-memory-db.pseudo  (REFERENCE DATA section, Agent SEED + Project SEED)
--
-- Both tables use INT GENERATED BY DEFAULT AS IDENTITY, so we use OVERRIDING SYSTEM VALUE
-- to force the sentinel id to 0. After insert we bump the identity sequence past MAX(id)
-- so subsequent app inserts do not collide with the sentinel.

INSERT INTO "Agent" (agent_id, name, description)
    OVERRIDING SYSTEM VALUE
    VALUES (0, {%~ $.quote('none') %}, {%~ $.quote('no attribution recorded') %})
    ON CONFLICT DO NOTHING;

INSERT INTO "Project" (project_id, agent_id, name, filepath, git_repo, main_branch, git_url)
    OVERRIDING SYSTEM VALUE
    VALUES (0, 0, {%~ $.quote('none') %}, {%~ $.quote('none') %}, {%~ $.quote('none') %}, {%~ $.quote('none') %}, {%~ $.quote('none') %})
    ON CONFLICT DO NOTHING;

SELECT setval(pg_get_serial_sequence('"Agent"', 'agent_id'), GREATEST(1, (SELECT MAX(agent_id) FROM "Agent")));
SELECT setval(pg_get_serial_sequence('"Project"', 'project_id'), GREATEST(1, (SELECT MAX(project_id) FROM "Project")));

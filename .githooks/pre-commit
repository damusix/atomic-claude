#!/usr/bin/env bash
# Pre-commit hook:
#   Stage 1 — render templates when a staged change touches templates/.
#              Re-stages commands/ outputs so they ride along with this commit.
#              The bundle stage below will then pick up the re-staged commands/.
#   Stage 2 — regenerate the embedded bundle when a staged change touches a
#              source artifact (agents/, commands/, skills/, output-styles/,
#              rules/, CLAUDE.md). Without this, CI fails the "Verify bundle
#              is committed" step.
# Installed by `make hooks` (sets core.hooksPath=.githooks).
set -euo pipefail

# Only react to staged changes (ignore unstaged edits — they aren't part of
# this commit).
mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACMR)

repo_root=$(git rev-parse --show-toplevel)

# --- Stage 1: render templates ---
needs_render=0
for f in "${staged[@]}"; do
    case "$f" in
        templates/*)
            needs_render=1
            break
            ;;
    esac
done

if [ "$needs_render" -eq 1 ]; then
    echo "pre-commit: templates changed — running make render"
    make -C "$repo_root" render >/dev/null
    # Re-stage rendered outputs so they ride along with this commit.
    git add "$repo_root/commands"
    echo "pre-commit: rendered outputs re-staged"
fi

# --- Stage 2: regenerate bundle ---
# After the render stage may have re-staged commands/, refresh the staged list
# so the bundle stage sees the updated set.
mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACMR)

needs_regen=0
for f in "${staged[@]}"; do
    case "$f" in
        agents/*|commands/*|skills/*|output-styles/*|rules/*|CLAUDE.md)
            needs_regen=1
            break
            ;;
    esac
done

if [ "$needs_regen" -eq 1 ]; then
    echo "pre-commit: source artifact changed — regenerating embedded bundle"
    make -C "$repo_root/atomic" bundle >/dev/null
    # Re-stage the bundle outputs so they ride along with this commit.
    git add "$repo_root/atomic/internal/embedded/bundle" "$repo_root/atomic/internal/embedded/manifest.go"
fi

# Surface drift the developer should know about.
if ! git diff --cached --quiet -- atomic/internal/embedded; then
    echo "pre-commit: bundle outputs re-staged"
fi

# Regenerate follow-ups INDEX.md when any entry file (other than INDEX.md
# itself) is staged. Skips silently if the atomic binary is not on PATH —
# fresh clones and pre-install states should commit without failing.
followups_touched=0
for f in "${staged[@]}"; do
    case "$f" in
        .claude/project/followups/INDEX.md) ;;
        .claude/project/followups/*.md)
            followups_touched=1
            break
            ;;
    esac
done

if [ "$followups_touched" -eq 1 ]; then
    if command -v atomic >/dev/null 2>&1; then
        atomic followups render >/dev/null
        git add "$repo_root/.claude/project/followups/INDEX.md"
        echo "pre-commit: follow-ups INDEX.md regenerated and re-staged"
    else
        echo "pre-commit: atomic binary not on PATH; skipping follow-ups INDEX regen" >&2
    fi
fi
